{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forge.dev/schemas/sequence-v1.schema.json",
  "title": "Forge request sequence (v1)",
  "description": "An explicit, ordered list of project-relative request documents.",
  "type": "object",
  "required": ["formatVersion", "kind", "meta", "requests"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "formatVersion": { "const": 1 },
    "kind": { "const": "sequence" },
    "meta": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "requests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).*\\.request\\.json$"
      }
    }
  }
}
