{
  "formatVersion": 1,
  "kind": "assertions",
  "assertions": [
    { "use": "builtin:assert-status@1", "with": { "expected": 200 } },
    { "use": "builtin:assert-header@1", "with": { "name": "Content-Type", "value": "application/json" } },
    { "use": "builtin:assert-json-path-type@1", "with": { "path": "$", "expected": "array" } },
    { "use": "builtin:assert-json-path-length@1", "with": { "path": "$", "operator": "equals", "expected": 2 } },
    { "use": "builtin:assert-response-time@1", "with": { "maxMs": 5000 } }
  ]
}
